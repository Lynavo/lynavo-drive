{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Mobile: iOS (macOS)",
      "type": "node-terminal",
      "request": "launch",
      "command": "cd \"${workspaceFolder}\" && corepack pnpm --filter @syncflow/mobile ios"
    },
    {
      "name": "Mobile: Metro (macOS)",
      "type": "node-terminal",
      "request": "launch",
      "command": "cd \"${workspaceFolder}\" && corepack pnpm --filter @syncflow/mobile start"
    },
    {
      "name": "Desktop: Dev",
      "type": "node-terminal",
      "request": "launch",
      "command": "cd \"${workspaceFolder}\" && corepack pnpm --filter @syncflow/desktop dev"
    },
    {
      "name": "Mobile: Android (quick launch)",
      "type": "node-terminal",
      "request": "launch",
      "command": "cd \"${workspaceFolder}\" && corepack pnpm --filter @syncflow/mobile exec react-native run-android --no-packager",
      "preLaunchTask": "mobile: start metro"
    }
  ]
}
